{
  "name": "geppetto-cli",
  "version": "0.1.0",
  "description": "Initialize Geppetto agent guidance files in a project",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/DaviRain-Su/geppetto.git"
  },
  "bin": {
    "geppetto-cli": "./bin/geppetto-cli.ts"
  },
  "files": [
    "bin/",
    "lib/",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "LICENSE",
    "LICENSE-APACHE",
    ".aider.conf.yml",
    ".amazonq/rules/geppetto.md",
    ".cursor/rules/geppetto.md",
    ".github/copilot-instructions.md",
    ".windsurf/rules/geppetto.md"
  ],
  "scripts": {
    "docs:check": "bun ./lib/knowledge-check.ts && bun ./lib/agent-entry-check.ts && bun ./lib/feature-matrix-check.ts && bun ./lib/upstream-version-check.ts && bun ./lib/site-check.ts && bun run e7:delivery -- --validate-only",
    "release:check": "bun ./lib/release-check.ts",
    "slides:dev": "slidev docs/platform/slides.md",
    "slides:build": "slidev build docs/platform/slides.md --out docs/platform/.slidev-dist",
    "slides:export": "slidev export docs/platform/slides.md",
    "geppetto:test": "bun ./bin/geppetto-cli.ts test",
    "geppetto:audit": "bun ./bin/geppetto-cli.ts audit",
    "geppetto:audit:strict": "bun ./bin/geppetto-cli.ts audit --strict",
    "test": "node --test --import tsx tests/cli/*.test.ts",
    "e7:readiness": "bun ./lib/e7-readiness-check.ts",
    "e7:delivery": "bun ./lib/e7-delivery-packet.ts",
    "upstream:check": "bun ./lib/upstream-diff-check.ts",
    "upstream:pr-body": "bun ./lib/upstream-pr-template.ts",
    "test:escrow-client-alignment": "cargo test --manifest-path examples/escrow/Cargo.toml --test generate_fixtures && tsx examples/escrow/tests/client_alignment.ts",
    "site:check": "bun ./lib/site-check.ts",
    "site:preview": "bunx wrangler pages dev site",
    "site:deploy": "bunx wrangler pages deploy site --project-name geppetto"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.3"
  },
  "packageManager": "bun@1.3.11",
  "devDependencies": {
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-default": "^0.25.0",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
